#!/bin/sh

# Lock the screen, handling caffeine toggle and audio mute around slock.
mpc pause
pauseallmpv
wpctl get-volume @DEFAULT_AUDIO_SINK@ | grep -q MUTED && wasmuted=1
wpctl set-mute @DEFAULT_AUDIO_SINK@ 1
kill -44 $(pidof dwmblocks)
xset q | grep -q "DPMS is Disabled" && { xset s default; xset +dpms; pkill -RTMIN+29 dwmblocks; }
slock
[ -n "$wasmuted" ] || wpctl set-mute @DEFAULT_AUDIO_SINK@ 0
kill -44 $(pidof dwmblocks)
pkill -RTMIN+29 dwmblocks
