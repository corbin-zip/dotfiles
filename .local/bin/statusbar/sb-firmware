#!/bin/sh

# Displays number of available firmware updates via fwupd.
# Reads locally cached LVFS metadata; refresh is handled by the
# fwupd-refresh.timer systemd unit (or run `fwupdmgr refresh` manually).
# Set the RTMIN signal in sb-popfwupd to match this block's signal in dwmblocks.h.

case $BLOCK_BUTTON in
	1) setsid -f "$TERMINAL" -e sb-popfwupd ;;
	2) notify-send "Firmware Updates" "$(fwupdmgr get-updates 2>&1)" ;;
	3) notify-send "🔩 Firmware module" "🔩: number of available firmware updates
- Left click to install firmware updates
- Middle click to show available updates" ;;
	6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

count=$(fwupdmgr get-updates 2>/dev/null | grep -c "New version:")
[ "$count" -gt 0 ] && printf "🔩%s" "$count"
