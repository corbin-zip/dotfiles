#!/bin/sh
# Shows Todoist tasks as 📋<overdue>/<today> (📋✓ when clear) using the td
# wrapper; caches the list under ~/.cache/sb-todoist so unattended refreshes
# are cheap. Left click opens a dmenu task picker (complete/postpone), middle
# click quick-adds a task in Todoist natural language ("dentist next monday
# 2pm p2"), right click shows details. `sb-todoist refresh` forces a refetch
# and bar redraw (use after changing tasks outside the module: CLI td, phone,
# web). calcurse stays in sync via td itself.

cache="${XDG_CACHE_HOME:-$HOME/.cache}/sb-todoist"
file="$cache/tasks.tsv"
maxage=540	# don't refetch more often than this on an unattended refresh
sig=13

fetch() { # only overwrites the cache on a successful fetch
	mkdir -p "$cache"
	td list >"$file.tmp" 2>/dev/null && mv "$file.tmp" "$file"
}

refresh() { fetch; pkill -RTMIN+$sig "${STATUSBAR:-dwmblocks}"; }

# Interactive flows re-invoke this script detached (setsid -f "$0" <cmd>) so
# a dmenu sitting open never blocks dwmblocks' click handler.
case "${1:-}" in
menu)
	[ -s "$file" ] || fetch
	choice=$(awk -F'\t' '{pri = ($3 == "-" ? "" : " "$3); print NR": "$2 pri"  "$4}' \
		"$file" | dmenu -i -l 15 -p "📋 overdue/today:") || exit 0
	n=${choice%%:*}
	id=$(awk -F'\t' -v n="$n" 'NR == n {print $1}' "$file")
	name=$(awk -F'\t' -v n="$n" 'NR == n {print $4}' "$file")
	[ -n "$id" ] || exit 0
	action=$(printf 'complete\npostpone: tomorrow\npostpone: next week\npostpone: ...\nnothing' |
		dmenu -i -p "$name:") || exit 0
	case "$action" in
	complete) out=$(td done "$id" >/dev/null && echo "completed: $name") ;;
	"postpone: tomorrow") out=$(td postpone "$id" tomorrow) ;;
	"postpone: next week") out=$(td postpone "$id" next week) ;;
	"postpone: ...")
		when=$(printf '' | dmenu -p "postpone to:") || exit 0
		[ -n "$when" ] || exit 0
		out=$(td postpone "$id" "$when")
		;;
	*) exit 0 ;;
	esac
	notify-send "📋 Todoist" "${out:-action failed}"
	refresh
	exit 0
	;;
add)
	text=$(printf '' | dmenu -p "📋 add task:") || exit 0
	[ -n "$text" ] || exit 0
	out=$(td add "$text")
	notify-send "📋 Todoist" "${out:-add failed}"
	refresh
	exit 0
	;;
refresh)
	refresh
	exit 0
	;;
esac

info() {
	[ -s "$file" ] || { notify-send "📋 Todoist module" \
		"No data yet — try a left click or check 'td list'."; return; }
	list=$(awk -F'\t' '{pri = ($3 == "-" ? "" : " "$3); print $2 pri "  " $4}' "$file")
	updated="$(date -d "@$(stat -c %Y "$file")" +'%b%-d %-I:%M%P' 2>/dev/null)"
	notify-send "📋 Todoist (overdue & today)" "${list:-all clear ✓}

Last updated ${updated:-never}
- Shows 📋 overdue/due-today
- Left click: pick a task to complete/postpone
- Middle click: quick-add (natural language)
- Right click: shows this info"
}

case $BLOCK_BUTTON in
	1) setsid -f "$0" menu >/dev/null 2>&1 ;;
	2) setsid -f "$0" add >/dev/null 2>&1 ;;
	3) info ;;
	6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

# Ensure we have data: fetch if the cache is missing, or if it's stale and
# this is an unattended refresh (no button press).
if [ ! -f "$file" ]; then
	fetch
elif [ -z "$BLOCK_BUTTON" ]; then
	age=$(( $(date +%s) - $(stat -c %Y "$file" 2>/dev/null || echo 0) ))
	[ "$age" -ge "$maxage" ] && fetch
fi

[ -f "$file" ] || { echo "📋✕"; exit 0; }
counts=$(awk -F'\t' -v today="$(date +%F)" \
	'$2 < today {o++} $2 == today {t++} END {print o+0 "/" t+0}' "$file")
[ "$counts" = "0/0" ] && echo "📋✓" || echo "📋$counts"
