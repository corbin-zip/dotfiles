#!/usr/bin/env bash

# dmenu theming
lines=(-l 20)

selected="$(ps -u "$USER" -o pid=,comm= |
	dmenu -i -c "${lines[@]}")"

[[ -n $selected ]] || exit 0

answer="$(printf 'Yes\nNo\n' |
	dmenu -i -c -p "$selected will be killed, ok?" "${lines[@]}")"

if [[ $answer == "Yes" ]]; then
	selpid="$(awk '{print $1}' <<<"$selected")"
	kill "$selpid" || notify-send "dmenukill" "Failed to kill $selected"
fi
