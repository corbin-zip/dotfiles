#!/usr/bin/env bash

# dmenu theming
lines="-l 20"

selected="$(ps -a -u "$USER" |
	dmenu -i -c \
		$lines |
	awk '{print $1" "$4}')"

if [[ -n $selected ]]; then

	answer="$(echo -e "Yes\nNo" |
		dmenu -i -c -p "$selected will be killed, ok?" \
			$lines)"

	if [[ $answer == "Yes" ]]; then
		selpid="$(awk '{print $1}' <<<"$selected")"
		kill -9 "$selpid"
	fi
fi

exit 0
