#!/bin/sh

# td - thin wrapper around the Todoist unified v1 API
# <https://developer.todoist.com/api/v1>. The single place anything on
# this machine talks to Todoist read/write: the statusbar module
# (sb-todoist) and Claude both call this instead of curl-ing the API
# themselves. Read-only calendar display stays with the iCal feed via
# cron/todoist-calcurse-sync.
#
# Needs TODOIST_API_TOKEN in ~/.config/shell/secretsrc
# (Todoist -> Settings -> Integrations -> Developer).
#
# Usage:
#   td add <text...>        natural language: "dentist next monday 2pm p2"
#   td list [query]         filter query, default: overdue | today
#   td get <id>             one task by id, even if completed
#   td done <id>            complete a task
#   td postpone <id> <when> reschedule: "tomorrow", "next sat", ...
#   td sync                 refresh calcurse from Todoist now
#
# `list` prints one task per line, tab-separated:
#   id <TAB> due-date <TAB> priority <TAB> content <TAB> time
# due-date is a local YYYY-MM-DD or "-" (undated); priority is p1..p3 or "-"
# (Todoist's API counts backwards: API 4 = UI p1 = most urgent); time is the
# local clock time ("7:00PM") for timed tasks, or "-" when all-day/undated.

api="https://api.todoist.com/api/v1"

. "${XDG_CONFIG_HOME:-$HOME/.config}/shell/secretsrc"

[ -n "${TODOIST_API_TOKEN:-}" ] || {
	echo "td: TODOIST_API_TOKEN not set in secretsrc" >&2
	exit 1
}

usage() {
	sed -n 's/^#   td/  td/p' "$0" >&2
	exit 64
}

req() { # req METHOD PATH [curl args...] -> body, fails on HTTP error
	method="$1" path="$2"
	shift 2
	curl -sSm 20 --fail-with-body -X "$method" \
		-H "Authorization: Bearer $TODOIST_API_TOKEN" \
		"$api$path" "$@"
}

# Kick the calcurse sync in the background after anything that changes
# Todoist, so the calendar/todo window catches up without waiting for cron.
syncsoon() { setsid -f "${0%/*}/cron/todoist-calcurse-sync" >/dev/null 2>&1; }

# Todoist hands back timed tasks as RFC3339 UTC stamps ("2026-06-13T23:00:00Z");
# date-only tasks as a plain "2026-06-13". localize reads the 4-column list/get
# TSV on stdin and rewrites the due column into the local date, appending a 5th
# "time" column ("7:00PM", or "-" when all-day/undated) so callers keep a plain
# local date for sorting/comparison while still showing a real clock time.
localize() {
	tab=$(printf '\t')
	while IFS="$tab" read -r id due pri content; do
		case "$due" in
		*T*)	d=$(date -d "$due" +%F 2>/dev/null) || d="$due"
			t=$(date -d "$due" +'%-I:%M%p' 2>/dev/null) || t="-" ;;
		*)	d="$due" t="-" ;;
		esac
		printf '%s\t%s\t%s\t%s\t%s\n' "$id" "$d" "$pri" "$content" "$t"
	done
}

# One-line local rendering of a raw due value for confirmations: "YYYY-MM-DD",
# or "YYYY-MM-DD 7:00PM" for timed tasks (passes non-timestamps through as-is).
fmtdue() {
	case "$1" in
	*T*)	printf '%s %s' "$(date -d "$1" +%F 2>/dev/null || printf %s "$1")" \
			"$(date -d "$1" +'%-I:%M%p' 2>/dev/null)" ;;
	*)	printf '%s' "$1" ;;
	esac
}

cmd="${1:-}"
[ $# -gt 0 ] && shift

case "$cmd" in
add)
	[ $# -gt 0 ] || usage
	body=$(jq -n --arg text "$*" '{text: $text}') || exit 1
	resp=$(req POST /tasks/quick -H "Content-Type: application/json" -d "$body") || {
		echo "td: add failed: $resp" >&2
		exit 1
	}
	due=$(echo "$resp" | jq -r '.due.date // ""')
	[ -n "$due" ] && due="  ($(fmtdue "$due"))"
	echo "added: $(echo "$resp" | jq -r '.content')$due"
	syncsoon
	;;
list)
	query="${*:-overdue | today}"
	cursor="" tasks=""
	while :; do
		page=$(req GET "/tasks/filter" -G \
			--data-urlencode "query=$query" \
			--data-urlencode "limit=200" \
			${cursor:+--data-urlencode "cursor=$cursor"}) || {
			echo "td: list failed: $page" >&2
			exit 1
		}
		tasks="$tasks$(echo "$page" | jq '.results[]')"
		cursor=$(echo "$page" | jq -r '.next_cursor // empty')
		[ -n "$cursor" ] || break
	done
	echo "$tasks" | jq -rs 'sort_by(.due.date // "9999-99-99")[] |
		[.id,
		 (.due.date // "-"),
		 (if .priority > 1 then "p\(5 - .priority)" else "-" end),
		 .content] | @tsv' | localize
	;;
get)
	# Same TSV as list, but priority column shows "done <date>" once the
	# task is completed. Used by the vault mirror check (notes annotate
	# migrated items with "(todoist:ID)"; see the task-assistant skill).
	[ $# -eq 1 ] || usage
	resp=$(req GET "/tasks/$1") || {
		echo "td: get failed: $resp" >&2
		exit 1
	}
	echo "$resp" | jq -r '[.id,
		 (.due.date // "-"),
		 (if .checked then "done \(.completed_at[:10] // "?")"
		  elif .priority > 1 then "p\(5 - .priority)" else "-" end),
		 .content] | @tsv' | localize
	;;
done)
	[ $# -eq 1 ] || usage
	resp=$(req POST "/tasks/$1/close") || {
		echo "td: done failed: $resp" >&2
		exit 1
	}
	echo "completed: $1"
	syncsoon
	;;
postpone)
	[ $# -ge 2 ] || usage
	id="$1"
	shift
	body=$(jq -n --arg due "$*" '{due_string: $due}') || exit 1
	resp=$(req POST "/tasks/$id" -H "Content-Type: application/json" -d "$body") || {
		echo "td: postpone failed: $resp" >&2
		exit 1
	}
	echo "postponed: $(echo "$resp" | jq -r '.content')  ($(fmtdue "$(echo "$resp" | jq -r '.due.date // .due.string')"))"
	syncsoon
	;;
sync)
	"${0%/*}/cron/todoist-calcurse-sync"
	;;
*)
	usage
	;;
esac
