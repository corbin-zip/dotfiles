#!/bin/sh

# Apply a fixed wal colorscheme (default: tokyonight-moon) through the
# normal theming pipeline. Leaves the wallpaper untouched; run `setbg` to
# go back to a wallpaper-derived scheme.

theme="${1:-tokyonight-moon}"

wal -n --theme "$theme" -o "${XDG_CONFIG_HOME:-$HOME/.config}/wal/postrun" >/dev/null 2>&1 &&
	notify-send "🎨 Applied wal theme" "$theme"
