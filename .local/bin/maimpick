#!/bin/sh

# This is bound to PrintScreen by default, requires maim. It lets you
# choose the kind of screenshot to take, including copying the image or even
# highlighting an area to copy.

# variables
output="$(date '+%y%m%d-%H%M-%S').png"
xclip_cmd="xclip -sel clip -t image/png"
ocr_cmd="xclip -sel clip"
menu_options="a selected area (copy)\ncopy selected image to text\ndecode QR code to clipboard\ncurrent window (copy)\nfull screen (copy)\na selected area\ncurrent window\nfull screen"

case "$(printf "$menu_options" | dmenu -l 8 -i -p "Screenshot which area?")" in
    "a selected area (copy)") maim -u -s | ${xclip_cmd} ;;
    "copy selected image to text") tmpfile=$(mktemp /tmp/ocr-XXXXXX.png) && maim -u -s | convert -resize 300% -sharpen 0x1 - "$tmpfile" && tesseract "$tmpfile" - -l eng --psm 6 | ${ocr_cmd} ; rm -f "$tmpfile" ;;
    "decode QR code to clipboard") qrclip ;;
    "current window (copy)") maim -q -d 0.2 -i "$(xdotool getactivewindow)" | ${xclip_cmd} ;;
    "full screen (copy)") maim -q -d 0.2 | ${xclip_cmd} ;;
    "a selected area") maim -u -s pic-selected-"${output}" ;;
    "current window") maim -B -q -d 0.2 -i "$(xdotool getactivewindow)" pic-window-"${output}" ;;
    "full screen") maim -q -d 0.2 pic-full-"${output}" ;;
esac
