#!/bin/sh

# This file runs when a DM logs you into a graphical session.
# If you use startx/xinit, this file will also be sourced.

DEVICE=$(uname -n)
USE_XRDB=true

if [ "$USE_XRDB" = true ]; then
    xrdb ${XDG_CONFIG_HOME:-$HOME/.config}/x11/xresources & xrdbpid=$!
fi

case "$DEVICE" in
    "spike")
        xrandr --dpi 180 &
        sh ./.screenlayout/currentbutslower.sh &
        autostart="picom dunst unclutter remaps protonmail-bridge synology-drive"
        redshift -P -O 3300 &
        rivalcfg -s 1100 -S 1300 &
        xwallpaper --zoom "${XDG_DATA_HOME:-$HOME/.local/share}/bg" &
        restoretheme &
        ;;
    "gaia")
        restoretheme &
        autostart="picom dunst unclutter remapd synology-drive"
        redshift -P -O 3300 &
        xwallpaper --zoom "${XDG_DATA_HOME:-$HOME/.local/share}/bg" &
        ;;
    "ganymede")
        xrandr --dpi 100 &
        xwallpaper --zoom "${XDG_DATA_HOME:-$HOME/.local/share}/bg" &
        restoretheme &
        autostart="mpd picom dunst unclutter remaps synology-drive"
        redshift -P -O 3300 &
        # enable natural scrolling on touchpad & decrease sensitivity of trackpoint
        tp_id=$(xinput list --id-only "TPPS/2 IBM TrackPoint")
        tpad_id=$(xinput list --id-only "SynPS/2 Synaptics TouchPad")
        [ -n "$tp_id" ] && xinput --set-prop "$tp_id" "libinput Accel Speed" -0.5 &
        [ -n "$tpad_id" ] && xinput --set-prop "$tpad_id" "libinput Natural Scrolling Enabled" 1 &
        ;;
    *)
        # Set DPI. User may want to use a larger number for larger screens.
        xrandr --dpi 96
        xwallpaper --zoom "${XDG_DATA_HOME:-$HOME/.local/share}/bg" &
        restoretheme &
        autostart="mpd picom dunst unclutter remapd"
        ;;
esac

for program in $autostart; do
	pidof -sx "$program" || "$program" &
done >/dev/null 2>&1

# Install yazi packages only if missing, so login doesn't hit the network.
if command -v ya > /dev/null
then
    yazidir=${XDG_CONFIG_HOME:-$HOME/.config}/yazi
    [ -d "$yazidir/flavors/tokyo-night.yazi" ] || ya pkg add BennyOe/tokyo-night
    [ -d "$yazidir/plugins/git.yazi" ] || ya pkg add yazi-rs/plugins:git
    [ -d "$yazidir/plugins/smart-enter.yazi" ] || ya pkg add yazi-rs/plugins:smart-enter
    [ -d "$yazidir/plugins/mime-ext.yazi" ] || ya pkg add yazi-rs/plugins:mime-ext
fi

# Ensure that xrdb has finished running before moving on to start the WM/DE.
if [ "$USE_XRDB" = true ]; then
    [ -n "$xrdbpid" ] && wait "$xrdbpid"
fi
