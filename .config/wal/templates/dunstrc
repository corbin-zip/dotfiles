[global]
    monitor = 0
    follow = keyboard
    width = 370
    height = 350
    offset = 0x19
    padding = 2
    horizontal_padding = 2
    transparency = 25
    font = Monospace 12
    format = "<b>%s</b>\n%b"

[urgency_low]
    background = "{color0}" # color0
    foreground = "{color8}" # color8
    timeout = 5s

[urgency_normal]
    foreground = "{color15}" # color15
    background = "{color0}" # color0
    frame_color = "{color4}" # color4
    timeout = 10s

[urgency_critical]
    background = "{color1}" # color1
    foreground = "{color0}" # color0
    frame_color = "{color11}" # color11
    timeout = 0

# Notification center capture (always on): runs notif-store for every
# notification, so the on-disk store is a complete log. always_run_script lets
# it fire even for notifications the DND rules below suppress. Absolute path so
# resolution does not depend on dunst's PATH.
[nc_capture]
    appname = "*"
    always_run_script = true
    script = /home/carbon/.local/bin/notif-store

# DND suppression: toggled at runtime by sb-dnd (dunstctl rule ... enable).
# Disabled at rest (re-asserted by wal/postrun after each dunst restart). Only
# low and normal urgency are matched, so critical alerts always pop through.
[nc_dnd_low]
    msg_urgency = low
    skip_display = true

[nc_dnd_normal]
    msg_urgency = normal
    skip_display = true
